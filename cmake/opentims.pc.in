prefix=@CMAKE_INSTALL_PREFIX@
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: opentims
Description: Open-source Bruker TimsTOF .d file reader
URL: https://github.com/michalsta/opentims
Version: @OPENTIMS_VERSION_FULL@
Libs: -L${libdir} -lopentims_cpp
Cflags: -I${includedir}
